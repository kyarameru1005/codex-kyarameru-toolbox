{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "request_id": {
      "type": "string",
      "description": "リクエスト識別子"
    },
    "mode": {
      "type": "string",
      "enum": ["map", "bridge", "formalize", "survey"],
      "description": "実行モード"
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "blocked"],
      "description": "処理の完了状態"
    },
    "topic": {
      "type": "string",
      "description": "探索対象の現象・概念"
    },
    "result": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string",
          "description": "結果の要約"
        },
        "frameworks_found": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "フレームワーク名"
              },
              "field": {
                "type": "string",
                "description": "出身分野"
              },
              "connection_type": {
                "type": "string",
                "enum": ["isomorphic", "analogous", "metaphorical", "speculative"],
                "description": "接続の確度（isomorphic が最強、speculative が最弱）"
              },
              "key_insight": {
                "type": "string",
                "description": "主要な知見"
              },
              "formalization_sketch": {
                "type": "string",
                "description": "定式化のスケッチ"
              },
              "limitations": {
                "type": "string",
                "description": "限界・適用条件"
              }
            }
          },
          "description": "発見されたフレームワーク群"
        },
        "cross_field_bridges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from_field": {
                "type": "string",
                "description": "接続元の分野"
              },
              "to_field": {
                "type": "string",
                "description": "接続先の分野"
              },
              "shared_structure": {
                "type": "string",
                "description": "共有される数理構造"
              },
              "transferable_techniques": {
                "type": "array",
                "items": { "type": "string" },
                "description": "転用可能な技法"
              },
              "known_examples": {
                "type": "array",
                "items": { "type": "string" },
                "description": "既知の成功例"
              }
            }
          },
          "description": "分野横断的な橋渡し"
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "探索的な未解決の問い"
        },
        "visualization_suggestions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "可視化の提案"
        }
      },
      "description": "探索結果"
    },
    "confidence_notes": {
      "type": "string",
      "description": "推測の度合い・前提の明示"
    },
    "further_directions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "探索の発展方向"
    },
    "artifacts_created": {
      "type": "array",
      "items": { "type": "string" },
      "description": "作成した成果物のパスリスト"
    },
    "next_action": {
      "type": "string",
      "description": "次のアクション提案 (proceed, clarify, blocked)"
    }
  },
  "required": [
    "request_id",
    "mode",
    "status",
    "topic",
    "result",
    "confidence_notes",
    "further_directions",
    "artifacts_created",
    "next_action"
  ],
  "additionalProperties": false
}
