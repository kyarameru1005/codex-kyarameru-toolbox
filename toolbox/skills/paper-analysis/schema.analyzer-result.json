{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "request_id": {
      "type": "string",
      "description": "リクエスト識別子"
    },
    "mode": {
      "type": "string",
      "enum": ["analyze", "methodology", "statistics", "claims"],
      "description": "実行モード"
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "blocked"],
      "description": "処理の完了状態"
    },
    "paper_info": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "論文タイトル" },
        "authors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "著者リスト"
        },
        "year": { "type": "string", "description": "出版年" },
        "journal": { "type": "string", "description": "ジャーナル名" },
        "field": { "type": "string", "description": "研究分野" },
        "research_questions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "研究課題"
        }
      },
      "description": "論文メタ情報"
    },
    "result": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string",
          "description": "分析結果の要約"
        },
        "claims": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim": { "type": "string", "description": "主張の内容" },
              "type": {
                "type": "string",
                "enum": ["fact", "inference", "opinion", "hypothesis"],
                "description": "主張の種類"
              },
              "evidence_strength": {
                "type": "string",
                "enum": ["strong", "moderate", "weak", "unsupported", "contradicted"],
                "description": "エビデンスの強さ"
              },
              "supporting_evidence": {
                "type": "array",
                "items": { "type": "string" },
                "description": "支持するエビデンス"
              }
            }
          },
          "description": "主張とエビデンスのマッピング"
        },
        "methodology_assessment": {
          "type": "object",
          "properties": {
            "design": { "type": "string", "description": "研究デザイン" },
            "strengths": {
              "type": "array",
              "items": { "type": "string" },
              "description": "方法論の強み"
            },
            "weaknesses": {
              "type": "array",
              "items": { "type": "string" },
              "description": "方法論の弱み"
            },
            "internal_validity": { "type": "string", "description": "内的妥当性評価" },
            "external_validity": { "type": "string", "description": "外的妥当性評価" }
          },
          "description": "方法論評価"
        },
        "statistical_assessment": {
          "type": "object",
          "properties": {
            "methods_used": {
              "type": "array",
              "items": { "type": "string" },
              "description": "使用された統計手法"
            },
            "issues": {
              "type": "array",
              "items": { "type": "string" },
              "description": "統計的問題点"
            },
            "effect_sizes_reported": { "type": "boolean", "description": "効果量の報告有無" },
            "confidence_intervals": { "type": "boolean", "description": "信頼区間の報告有無" }
          },
          "description": "統計分析評価"
        },
        "strengths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "論文の強み"
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string" },
          "description": "論文の限界"
        },
        "biases_detected": {
          "type": "array",
          "items": { "type": "string" },
          "description": "検出されたバイアス"
        }
      },
      "description": "分析結果"
    },
    "issues_found": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["methodological", "statistical", "logical", "reporting", "ethical"],
            "description": "問題の種類"
          },
          "location": { "type": "string", "description": "問題箇所（セクション等）" },
          "description": { "type": "string", "description": "問題の説明" },
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor"],
            "description": "深刻度"
          },
          "suggestion": { "type": "string", "description": "改善提案" }
        }
      },
      "description": "発見された問題点"
    },
    "artifacts_created": {
      "type": "array",
      "items": { "type": "string" },
      "description": "作成した成果物のパスリスト"
    },
    "next_action": {
      "type": "string",
      "description": "次のアクション提案 (proceed, clarify, blocked)"
    }
  },
  "required": [
    "request_id",
    "mode",
    "status",
    "paper_info",
    "result",
    "issues_found",
    "artifacts_created",
    "next_action"
  ],
  "additionalProperties": false
}
