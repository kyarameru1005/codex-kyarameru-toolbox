{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkerResult",
  "description": "MCP Worker の最終出力スキーマ",
  "type": "object",
  "properties": {
    "request_id": {
      "type": "string",
      "description": "リクエスト識別子"
    },
    "status": {
      "type": "string",
      "enum": ["success", "error"],
      "description": "処理結果のステータス"
    },
    "summary": {
      "type": "string",
      "description": "結果の要約（1-2文）"
    },
    "answer_markdown": {
      "type": "string",
      "description": "詳細な回答（Markdown形式）"
    },
    "error_message": {
      "type": "string",
      "description": "エラー時のメッセージ（status=error時のみ）"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "情報源のリスト（URL、ファイルパス等）"
    }
  },
  "required": ["request_id", "status", "summary", "answer_markdown"],
  "additionalProperties": false
}
